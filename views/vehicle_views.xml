<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_plate_vehicle_tree" model="ir.ui.view">
        <field name="name">plate.vehicle.tree</field>
        <field name="model">plate.vehicle</field>
        <field name="arch" type="xml">
            <list string="English Plates">
                <field name="model_name"/>
                <field name="license_plate"/>
                <field name="tag_ids" widget="many2many_tags"/>
            </list>
        </field>
    </record>

    <record id="view_plate_vehicle_form" model="ir.ui.view">
        <field name="name">plate.vehicle.form</field>
        <field name="model">plate.vehicle</field>
        <field name="arch" type="xml">
            <form string="Vehicle">
                <sheet>
                    <group>
                        <field name="model_name"/>
                        <field name="plate_image" widget="image"/>
                        <field name="license_plate" readonly="1" force_save="1"/>
                        <field name="tag_ids" widget="many2many_tags"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_plate_vehicle" model="ir.actions.act_window">
        <field name="name">English Plates</field>
        <field name="res_model">plate.vehicle</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
